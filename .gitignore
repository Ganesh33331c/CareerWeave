# =============================================================================
# .gitignore — CareerWeave
# NEVER commit secrets, virtual envs, or local artefacts to your repo.
# =============================================================================

# ── Secrets & credentials (CRITICAL) ─────────────────────────────────────────
.env
.env.*
*.key
*.pem
service-account*.json
gcp-credentials*.json
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.log

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Uploaded test resumes (local testing only) ────────────────────────────────
test_resumes/
sample_resume*.pdf
sample_resume*.docx

# ── Local Streamlit cache ─────────────────────────────────────────────────────
.streamlit/secrets.toml
